DirectoryIndex blog-capvietnam.php index.html index.php

RewriteEngine On

# Force HTTPS + www canonique (une seule règle — max 1 redirect HTTP→HTTPS+www)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.blog-capvietnam.fr%{REQUEST_URI} [R=301,L]

# blog-capvietnam(.php) → /  (canonical home — avec et sans extension)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/blog-capvietnam(\.php)?[\s?/] [NC]
RewriteRule ^ / [R=301,L]

# Redirect .php → clean URL (pages publiques seulement)
# Exclure : go.php + scripts fonctionnels (handlers POST/AJAX/admin)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^/]+)\.php[\s?/] [NC]
RewriteCond %1 !^(go|generate-sitemap|convert-images-to-webp|mailerlite-subscribe|indexnow-ping|setup-indexnow|stats-affilies|lead-magnet)$
RewriteRule ^([^/]+)\.php$ /$1 [R=301,L]

# Accès racine → blog-capvietnam.php (interne)
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /blog-capvietnam.php [L]

# URLs propres : /slug → /slug.php (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# URLs propres pour /vi/ : /vi/slug → /vi/slug.php (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(vi/[^/]+)$ $1.php [L]

# Affiliate redirect : /go/wise → go.php?id=wise (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^go/([a-z0-9_-]+)$ go.php?id=$1 [L,QSA]