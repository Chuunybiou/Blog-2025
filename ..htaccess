DirectoryIndex blog-capvietnam.php index.html index.php

RewriteEngine On

# Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# blog-capvietnam.php → /  (canonical home)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/blog-capvietnam\.php[\s?/] [NC]
RewriteRule ^ / [R=301,L]

# Redirect .php → clean URL (pages publiques seulement)
# Exclure : go.php, generate-sitemap.php, convert-images-to-webp.php
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^/]+)\.php[\s?/] [NC]
RewriteCond %1 !^(go|generate-sitemap|convert-images-to-webp)$
RewriteRule ^([^/]+)\.php$ /$1 [R=301,L]

# Accès racine → blog-capvietnam.php (interne)
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /blog-capvietnam.php [L]

# URLs propres : /slug → /slug.php (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# URLs propres pour /vi/ : /vi/slug → /vi/slug.php (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(vi/[^/]+)$ $1.php [L]

# Affiliate redirect : /go/wise → go.php?id=wise (interne)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^go/([a-z0-9_-]+)$ go.php?id=$1 [L,QSA]