DirectoryIndex blog-capvietnam.html index.html index.php

RewriteEngine On

# Forcer HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Rediriger vers blog-capvietnam.php si accès racine
RewriteCond %{REQUEST_URI} ^/$
RewriteRule ^$ /blog-capvietnam.php [L]

# URLs propres : /slug → /slug.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]

# URLs propres pour /vi/ : /vi/slug → /vi/slug.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(vi/[^/]+)$ $1.php [L]

# Affiliate redirect clean URLs: /go/wise → /go.php?id=wise
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^go/([a-z0-9_-]+)$ go.php?id=$1 [L,QSA]