Options -Indexes
ErrorDocument 404 /404-capvietnam.php
RewriteEngine On

# www → non-www
RewriteCond %{HTTP_HOST} ^www\.blog-capvietnam\.fr$ [NC]
RewriteRule ^ https://blog-capvietnam.fr%{REQUEST_URI} [R=301,L]

# Racine → page d'accueil
RewriteRule ^$ blog-capvietnam.php [L]

# go.php — ne jamais réécrire
RewriteRule ^go\.php$ - [L]

# Redirect slug.php → slug sans extension (301)
RewriteCond %{THE_REQUEST} \s/(.+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Réécriture interne : slug → slug.php (racine et sous-dossiers)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.+)$ $1.php [L]